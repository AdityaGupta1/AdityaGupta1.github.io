---
import { ClientRouter, fade } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';
import '../styles/main.scss';
import '../styles/swag.css';

interface Props {
  currentPage: string;
}

const { currentPage } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Aditya Gupta</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />

    <ClientRouter />

    <!-- async CSS loading -->
    <link rel="stylesheet" href="/assets/css/fontawesome-all.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,300italic,400,600" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" media="print" onload="this.media='all'" />

    <link rel="icon" type="image/webp" href="/images/avatar-icon.webp" />

    <script src="/assets/js/lazysizes.min.js" defer></script>
  </head>
  <body class="is-preload">

    <Sidebar currentPage={currentPage} transition:persist />

    <div id="headerToggle" transition:persist><div id="headerToggleInside">
      <a href="#header" class="toggle"></a>
    </div></div>

    <div id="main-flex">
      <div id="main">
        <div transition:animate={fade}>
          <slot />
        </div>
      </div>

      <div id="footer">
        <ul class="copyright">
          <li>&copy; 2026 Aditya Gupta. All rights reserved.</li><li>Design: <a href="http://html5up.net" target="_blank">HTML5 UP</a></li>
        </ul>
      </div>
    </div>

    <!-- Panel toggle (replaces jQuery panel) -->
    <script>
      function initPanel() {
        const body = document.body;
        const header = document.getElementById('header');
        const toggleLink = document.querySelector('#headerToggle a.toggle');

        // Remove preload class
        body.classList.remove('is-preload');

        // Toggle sidebar
        if (toggleLink) {
          toggleLink.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            body.classList.toggle('header-visible');
          });
        }

        // Close sidebar on body click (but not clicks inside header)
        body.addEventListener('click', function() {
          if (body.classList.contains('header-visible')) {
            body.classList.remove('header-visible');
          }
        });

        // Prevent clicks inside header from closing it
        if (header) {
          header.addEventListener('click', function(e) {
            e.stopPropagation();
          });
        }

        // Swipe to dismiss (left panel)
        let touchStartX = 0;
        let touchStartY = 0;

        if (header) {
          header.addEventListener('touchstart', function(e) {
            touchStartX = e.touches[0].pageX;
            touchStartY = e.touches[0].pageY;
          });

          header.addEventListener('touchmove', function(e) {
            const diffX = touchStartX - e.touches[0].pageX;
            const diffY = touchStartY - e.touches[0].pageY;
            if (Math.abs(diffY) < 20 && diffX > 50) {
              body.classList.remove('header-visible');
              touchStartX = 0;
              touchStartY = 0;
            }
          });
        }

        // Close sidebar on nav link click (mobile)
        document.querySelectorAll('#nav a').forEach(function(a) {
          a.addEventListener('click', function() {
            if (body.classList.contains('header-visible')) {
              body.classList.remove('header-visible');
            }
          });
        });
      }

      function updateActiveNav() {
        const path = window.location.pathname;
        const navMap: Record<string, string> = {
          '/': 'nav-projects',
          '/art': 'nav-art',
          '/photography': 'nav-photography',
          '/about': 'nav-about',
        };

        document.querySelectorAll('#nav a').forEach(a => a.classList.remove('active'));

        for (const [prefix, id] of Object.entries(navMap)) {
          if (prefix === '/' ? path === '/' : path.startsWith(prefix)) {
            document.getElementById(id)?.classList.add('active');
            break;
          }
        }
      }

      initPanel();
      document.addEventListener('astro:after-swap', () => {
        updateActiveNav();
      });
    </script>

    <!-- Fancybox -->
    <script>
      import { Fancybox } from '@fancyapps/ui';
      import '@fancyapps/ui/dist/fancybox/fancybox.css';

      function initFancybox() {
        Fancybox.destroy();
        Fancybox.defaults.Hash = false;
        Fancybox.bind("[data-fancybox]", {
          on: {
            init: () => {
              const toggle = document.getElementById('headerToggleInside');
              if (toggle) {
                toggle.style.opacity = '0';
                toggle.style.pointerEvents = 'none';
              }
            },
            shouldClose: () => {
              const toggle = document.getElementById('headerToggleInside');
              if (toggle) {
                toggle.style.opacity = '1';
                toggle.style.pointerEvents = '';
              }
            },
          },
          Images: { protected: true },
        });
      }

      initFancybox();
      document.addEventListener('astro:after-swap', initFancybox);
    </script>
  </body>
</html>
